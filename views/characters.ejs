<%- include('partials/header') %>

<h1><%= data.title %></h1>

<div class="card-grid">
<% data.items.forEach(function(char) { %>
  <div class="card">
    <h3><%= char.name %></h3>
    <div class="card-subtitle"><%= char.role %></div>
    <p style="text-indent:0;"><%= char.description %></p>
    <% if (char.traits) { %>
      <div class="card-traits"><%= char.traits %></div>
    <% } %>
  </div>
<% }); %>
</div>

<%- include('partials/footer') %>
